@model IEnumerable<ReservationSystem.Models.Sınıflar.ContactMessage>
@{ ViewBag.Title = "Mesajlar"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; }

<h2 style="color:#8e44ad; border-bottom:2px solid #ddd; padding-bottom:10px;">📩 Gelen Mesajlar</h2>

<div style="background:#fff; padding:20px; border-radius:8px; margin-top:20px;">
    <table class="data-table" style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="background:#f8f9fa; text-align:left;">
                <th style="padding:10px;">Tarih</th>
                <th style="padding:10px;">Kimden</th>
                <th style="padding:10px;">Konu</th>
                <th style="padding:10px; width:40%;">Mesaj</th>
                <th style="padding:10px;">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:10px;">@item.SentDate.ToString("dd.MM HH:mm")</td>
                    <td style="padding:10px;">
                        <strong>@item.SenderName</strong><br>
                        <small>@item.SenderEmail</small>
                    </td>
                    <td style="padding:10px; color:#8e44ad;">@item.Subject</td>
                    <td style="padding:10px;">@item.MessageBody</td>
                    <td style="padding:10px;">
                        @using (Html.BeginForm("Delete", "ContactAdmin", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.MessageID" />
                            <button class="btn-delete-sm" onclick="return confirm('Silinsin mi?')">Sil</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {<p style="padding:20px; text-align:center; color:#999;">Mesaj yok.</p>}
</div>