@model IEnumerable<ReservationSystem.Models.Sınıflar.Reservation>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Katılımcı Listesi</title>
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap" rel="stylesheet">
    <style>

        body {
            background-color: #e9ecef; 
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            padding: 40px 0;
            display: flex;
            justify-content: center;
        }

 
        .report-paper {
            background-color: #fff;
            width: 210mm; 
            min-height: 297mm; 
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15); 
            box-sizing: border-box;
            position: relative;
        }

        .report-header {
            border-bottom: 3px solid #8e44ad; 
            padding-bottom: 20px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .report-title h1 {
            margin: 0;
            color: #333;
            font-size: 24px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .report-meta {
            text-align: right;
            font-size: 14px;
            color: #666;
        }

        .report-meta span {
            display: block;
            margin-bottom: 5px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        th {
            background-color: #8e44ad; 
            color: #fff;
            text-align: left;
            padding: 12px;
            font-weight: 600;
        }

        td {
            border-bottom: 1px solid #eee;
            padding: 10px 12px;
            color: #444;
        }

        tr:nth-child(even) {
            background-color: #f8f9fa; 
        }

        .btn-print {
            position: fixed;
            top: 20px;
            right: 20px;
            background-color: #333;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: all 0.2s;
            z-index: 1000;
        }

        .btn-print:hover {
            background-color: #8e44ad;
            transform: translateY(-2px);
        }

        @@media print {
            body {
                background-color: #fff;
                padding: 0;
            }
            .report-paper {
                box-shadow: none;
                width: 100%;
                margin: 0;
                padding: 20px;
            }
            .btn-print {
                display: none; 
            }
        }
    </style>
</head>
<body>

    <button onclick="window.print()" class="btn-print">🖨️ YAZDIR / PDF</button>

    <div class="report-paper">

        @if (Model.Any())
        {
            var evt = Model.First().Event;

            <div class="report-header">
                <div class="report-title">
                    <span style="font-size:12px; color:#8e44ad; font-weight:bold;">ETKİNLİK RAPORU</span>
                    <h1>@evt.Name</h1>
                </div>
                <div class="report-meta">
                    <span>📅 <strong>Tarih:</strong> @evt.Date.ToString("dd MMMM yyyy, HH:mm")</span>
                    <span>📍 <strong>Konum:</strong> @evt.Location</span>
                    <span>👥 <strong>Toplam:</strong> @Model.Count() Kişi</span>
                </div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Rezervasyon Tarihi</th>
                       
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><b>@(i++)</b></td>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.ReservationDate.ToString("dd.MM.yyyy")</td>
                            <td></td>
                        </tr>
                    }
                </tbody>
            </table>

            <div style="margin-top: 50px; text-align: center; color: #999; font-size: 12px; border-top: 1px solid #eee; padding-top: 10px;">
                Bu rapor @DateTime.Now.ToString("dd.MM.yyyy HH:mm") tarihinde BiletBul Yönetim Paneli'nden oluşturulmuştur.
            </div>
        }
        else
        {
            <div style="text-align:center; padding: 100px; color:#999;">
                <h2>Kayıt Bulunamadı</h2>
                <p>Bu etkinlik için henüz oluşturulmuş bir rezervasyon yok.</p>
            </div>
        }
    </div>

</body>
</html>