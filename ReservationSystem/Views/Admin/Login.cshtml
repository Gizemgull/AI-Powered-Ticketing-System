@{
    Layout = null;
    ViewBag.Title = "Admin Girişi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - BiletBul Yönetim Paneli</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        
        body {
            margin: 0; padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            height: 100vh;
            display: flex; justify-content: center; align-items: center;
        }
        .login-card {
            background-color: #fff; border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            display: flex; overflow: hidden;
            width: 900px; max-width: 95%; min-height: 550px;
        }
        .login-illustration {
            flex: 1; background-color: #f0f2f5;
            display: flex; justify-content: center; align-items: center; padding: 40px;
            flex-direction: column;
        }
        .login-form-container {
            flex: 1; padding: 50px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .login-header h2 { color: #333; margin-bottom: 30px; font-size: 28px; }

        .form-group { margin-bottom: 20px; position: relative; }

  
        .form-control-custom {
            width: 100%; padding: 15px 50px 15px 20px;
            border: 2px solid #eee; border-radius: 50px;
            font-size: 15px; outline: none; box-sizing: border-box; transition: 0.3s;
        }
        .form-control-custom:focus { border-color: #8e44ad; }


        .form-icon { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: #aaa; pointer-events: none;}


        .btn-login {
            width: 100%; padding: 15px; border: none; border-radius: 50px;
            background-color: #8e44ad; color: white; font-weight: bold; cursor: pointer;
            transition: 0.3s; font-size: 16px;
        }
        .btn-login:hover { background-color: #732d91; transform: translateY(-2px); }

        .text-danger { color: red; margin-bottom: 15px; }

        @@media (max-width: 768px) {
            .login-card { flex-direction: column; width: 90%; }
            .login-illustration { display: none; }
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-illustration">
            <h1 style="color:#8e44ad; font-size: 40px; margin:0;">BiletBul</h1>
            <p style="color:#666; margin-top:10px;">Yönetim Paneli</p>
        </div>

        <div class="login-form-container">
            <div class="login-header"><h2>Giriş Yap</h2></div>

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            @using (Html.BeginForm("Login", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <input type="text" name="Username" class="form-control-custom" placeholder="Kullanıcı Adı" required autocomplete="off" />
                    <i class="fas fa-user form-icon"></i>
                </div>

                <div class="form-group">
                    <input type="password" name="Password" class="form-control-custom" placeholder="Şifre" required />
                    <i class="fas fa-lock form-icon"></i>
                </div>

                <button type="submit" class="btn-login">GİRİŞ YAP</button>
            }
        </div>
    </div>
</body>
</html>